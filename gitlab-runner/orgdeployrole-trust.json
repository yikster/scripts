{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "TrustRunnerRoleForCrossAccountDeploy",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::999999999999:role/RunnerRole"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": {
          "sts:ExternalId": "REPLACE-WITH-SHARED-EXTERNAL-ID"
        }
      }
    }
  ]
}
